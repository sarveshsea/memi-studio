{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mémoire Studio",
  "version": "0.18.0",
  "identifier": "cv.memoire.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run tauri:build-runtime",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mémoire Studio",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:8765",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/memi-studio-runtime"],
    "resources": ["resources/memoire-runtime"],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
