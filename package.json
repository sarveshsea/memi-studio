{
  "name": "memi-studio",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Humyn LLC",
  "homepage": "https://github.com/sarveshsea/memi-studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarveshsea/memi-studio.git"
  },
  "memoireRuntime": {
    "version": "0.20.0",
    "engineRepo": "sarveshsea/memi",
    "releaseTag": "runtime-v0.20.0",
    "binaryAssetPattern": "memi-studio-runtime-{arch}-apple-darwin",
    "resourcesAsset": "memoire-runtime-resources-0.20.0.tar.gz"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1421",
    "fetch:runtime": "node scripts/fetch-runtime.mjs",
    "test:runtime-fetch": "node scripts/fetch-runtime-cache.test.mjs",
    "test:workbench-context": "node scripts/run-workbench-context-tests.mjs",
    "test:no-mock-ui": "node scripts/assert-no-mock-ui.mjs",
    "test:no-empty-catch": "node scripts/assert-no-empty-catch.mjs",
    "test:unit": "vitest run",
    "test:live-agents": "node scripts/studio-live-agent-smoke.mjs",
    "test:live-e2e": "node scripts/studio-live-e2e.mjs",
    "test:e2e-surfaces": "node scripts/studio-e2e-surface-smoke.mjs",
    "check:rust": "CARGO_TARGET_DIR=$HOME/Library/Caches/cv.memoire.studio/cargo-target cargo test --manifest-path src-tauri/Cargo.toml && CARGO_TARGET_DIR=$HOME/Library/Caches/cv.memoire.studio/cargo-target cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "license:check": "node scripts/apply-license-headers.mjs --check",
    "license:apply": "node scripts/apply-license-headers.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run fetch:runtime && CARGO_TARGET_DIR=$HOME/Library/Caches/cv.memoire.studio/cargo-target tauri dev",
    "tauri:build": "npm run fetch:runtime -- --all-archs && node scripts/clean-local-tauri-artifacts.mjs && CARGO_TARGET_DIR=$HOME/Library/Caches/cv.memoire.studio/cargo-target PATH=$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH tauri build --config src-tauri/tauri.local.conf.json",
    "tauri:build:release": "npm run fetch:runtime -- --all-archs && CARGO_TARGET_DIR=${CARGO_TARGET_DIR:-$HOME/Library/Caches/cv.memoire.studio/cargo-target} PATH=$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "elkjs": "^0.11.1",
    "mermaid": "^11.15.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tldraw": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "^4.1.10"
  }
}
