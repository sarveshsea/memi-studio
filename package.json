{
  "name": "memi-studio",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "license": "FSL-1.1-ALv2",
  "author": "Humyn LLC",
  "homepage": "https://github.com/sarveshsea/memi-studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarveshsea/memi-studio.git"
  },
  "memoireRuntime": {
    "version": "0.18.2",
    "engineRepo": "sarveshsea/memi",
    "releaseTag": "runtime-v0.18.2",
    "binaryAssetPattern": "memi-studio-runtime-{arch}-apple-darwin",
    "resourcesAsset": "memoire-runtime-resources-0.18.0.tar.gz"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1421",
    "fetch:runtime": "node scripts/fetch-runtime.mjs",
    "test:workbench-context": "node scripts/run-workbench-context-tests.mjs",
    "test:no-mock-ui": "node scripts/assert-no-mock-ui.mjs",
    "test:live-agents": "node scripts/studio-live-agent-smoke.mjs",
    "check:rust": "cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "license:check": "node scripts/apply-license-headers.mjs --check",
    "license:apply": "node scripts/apply-license-headers.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run fetch:runtime && tauri dev",
    "tauri:build": "npm run fetch:runtime && node scripts/clean-local-tauri-artifacts.mjs && PATH=$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH tauri build --config src-tauri/tauri.local.conf.json",
    "tauri:build:release": "npm run fetch:runtime && PATH=$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "elkjs": "^0.11.1",
    "mermaid": "^11.15.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tldraw": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.11"
  }
}
